enum MonitorType {
  HTTP
  PING
  DNS
  SSL
}

model StatusPage {
  id          String   @id @default(uuid())
  title       String
  description String?
  monitorId   String   @unique
  monitor     Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

enum REGION {
  US
  EU
  INDIA
}

model MonitorCheckResult {
  id         String        @id @default(uuid())
  monitorId  String
  region     REGION
  status     MonitorStatus
  startedAt  DateTime
  finishedAt DateTime
  durationMs Int?
  summary    String?
  details    Json
  createdAt  DateTime      @default(now())

  monitor Monitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@index([monitorId, createdAt])
  @@index([monitorId, region, createdAt])
}

enum MonitorStatus {
  UP
  DOWN
  DEGRADED
  UNKNOWN
}

model NotificationChannel {
  id        String   @id @default(uuid())
  userId    String
  type      String // "email" | "sms" | "slack"
  config    Json // { "email": "john@doe.com" }
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user                        User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  monitorNotificationChannels MonitorNotificationChannel[]
  alertDeliveries             AlertDelivery[]
}

model MonitorNotificationChannel {
  monitorId             String
  notificationChannelId String
  notificationChannel   NotificationChannel @relation(fields: [notificationChannelId], references: [id], onDelete: Cascade)
  monitor               Monitor             @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@id([monitorId, notificationChannelId])
}

model Incident {
  id            String         @id @default(cuid())
  monitorId     String
  status        IncidentStatus @default(OPEN)
  severity      String?
  startedAt     DateTime       @default(now())
  resolvedAt    DateTime?
  lastAlertedAt DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  monitor         Monitor         @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  incidentEvents  IncidentEvent[]
  alertDeliveries AlertDelivery[]

  @@index([monitorId])
  @@index([monitorId, status])
}

enum IncidentStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

model AlertDelivery {
  id                    String   @id @default(uuid())
  incidentId            String
  notificationChannelId String
  eventType             String
  status                String?
  providerMessage       String?
  createdAt             DateTime @default(now())

  incident            Incident            @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  notificationChannel NotificationChannel @relation(fields: [notificationChannelId], references: [id], onDelete: Cascade)

  @@index([incidentId])
}

model IncidentEvent {
  id         String   @id @default(cuid())
  incidentId String
  type       String
  message    String
  createdAt  DateTime @default(now())

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId])
}

model Session {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent  String?
  ipAddress  String?
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())
  expiresAt  DateTime?

  @@index([userId, lastSeenAt])
}
