generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Core users & auth
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  firstName String
  lastName  String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions          Session[]
  memberships       TeamMembership[]
  contacts          NotificationChannel[] // personal contact methods
  createdMonitors   Monitor[]             @relation("MonitorCreator")
  layerParticipants LayerParticipant[]
  scheduleOverrides ScheduleOverride[]
  escalationSteps   EscalationStep[] // when targetType=USER
  alertDeliveries   AlertDelivery[] // who was actually paged
}

model Session {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent  String?
  ipAddress  String?
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  expiresAt  DateTime?

  @@index([userId, lastSeenAt])
}

// Tenancy & access
model Team {
  id        String   @id @default(uuid())
  name      String
  slug      String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships        TeamMembership[]
  monitors           Monitor[]
  schedules          OnCallSchedule[]
  escalationPolicies EscalationPolicy[]
}

model TeamMembership {
  id        String           @id @default(uuid())
  teamId    String
  userId    String
  role      TeamRole         @default(MEMBER)
  status    MembershipStatus @default(ACTIVE)
  createdAt DateTime         @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

enum TeamRole {
  ADMIN
  MEMBER
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
  REMOVED
}

// Monitoring
model Monitor {
  id                 String      @id @default(uuid())
  teamId             String
  createdById        String?
  name               String
  type               MonitorType
  target             String
  regions            REGION[]
  intervalSec        Int         @default(60)
  nextCheckAt        DateTime    @default(now())
  paused             Boolean     @default(false)
  config             Json
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  escalationPolicyId String?

  team                        Team                         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdBy                   User?                        @relation("MonitorCreator", fields: [createdById], references: [id], onDelete: SetNull)
  escalationPolicy            EscalationPolicy?            @relation(fields: [escalationPolicyId], references: [id])
  checkResults                MonitorCheckResult[]
  statusPage                  StatusPage?
  incidents                   Incident[]
  monitorNotificationChannels MonitorNotificationChannel[]

  @@index([teamId])
  @@index([nextCheckAt, paused])
}

enum MonitorType {
  HTTP
  PING
  DNS
  SSL
}

enum REGION {
  US
  EU
  ASIA
}

// Status pages
model StatusPage {
  id          String   @id @default(uuid())
  title       String
  description String?
  monitorId   String   @unique
  monitor     Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

// Check results & incidents
model MonitorCheckResult {
  id         String        @id @default(uuid())
  monitorId  String
  region     REGION
  status     MonitorStatus
  startedAt  DateTime
  finishedAt DateTime
  durationMs Int?
  summary    String?
  details    Json
  createdAt  DateTime      @default(now())

  monitor Monitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@index([monitorId, createdAt])
  @@index([monitorId, region, createdAt])
}

enum MonitorStatus {
  UP
  DOWN

  DEGRADED

  UNKNOWN
}

model Incident {
  id            String         @id @default(uuid())
  monitorId     String
  status        IncidentStatus @default(OPEN)
  severity      String?
  startedAt     DateTime       @default(now())
  resolvedAt    DateTime?
  lastAlertedAt DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  monitor         Monitor         @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  incidentEvents  IncidentEvent[]
  alertDeliveries AlertDelivery[]

  @@index([monitorId])
  @@index([monitorId, status])
}

enum IncidentStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

model IncidentEvent {
  id         String   @id @default(cuid())
  incidentId String
  type       String
  message    String
  createdAt  DateTime @default(now())

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId])
}

// Notification channels (personal)
model NotificationChannel {
  id        String   @id @default(uuid())
  userId    String
  type      String // email | sms | voice | slack | webhook
  config    Json
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user                        User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  monitorNotificationChannels MonitorNotificationChannel[]
  alertDeliveries             AlertDelivery[]
}

// Legacy/static monitor → channel links (kept as fallback)
model MonitorNotificationChannel {
  monitorId             String
  notificationChannelId String
  notificationChannel   NotificationChannel @relation(fields: [notificationChannelId], references: [id], onDelete: Cascade)
  monitor               Monitor             @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@id([monitorId, notificationChannelId])
}

// On‑call schedules
model OnCallSchedule {
  id        String   @id @default(uuid())
  teamId    String
  name      String
  timezone  String // IANA
  createdAt DateTime @default(now())

  team            Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)
  layers          ScheduleLayer[]
  overrides       ScheduleOverride[]
  escalationSteps EscalationStep[]
}

model ScheduleLayer {
  id           String             @id @default(uuid())
  scheduleId   String
  order        Int
  shiftMinutes Int
  startsAt     DateTime
  rotationType RotationType       @default(FIXED)
  participants LayerParticipant[]

  schedule OnCallSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
}

enum RotationType {
  FIXED
  WEEKLY
  CUSTOM
}

model LayerParticipant {
  id        String   @id @default(uuid())
  layerId   String
  userId    String
  position  Int // rotation order
  createdAt DateTime @default(now())

  layer ScheduleLayer @relation(fields: [layerId], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([layerId, position])
  @@unique([layerId, userId]) // prevent duplicates in a layer
}

model ScheduleOverride {
  id         String   @id @default(uuid())
  scheduleId String
  userId     String
  startsAt   DateTime
  endsAt     DateTime
  reason     String?

  schedule OnCallSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([scheduleId, startsAt, endsAt])
}

// Escalation policies
model EscalationPolicy {
  id        String   @id @default(uuid())
  teamId    String
  name      String
  repeat    Int      @default(0) // loops after last step
  createdAt DateTime @default(now())

  team     Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  steps    EscalationStep[]
  monitors Monitor[]
}

model EscalationStep {
  id           String           @id @default(uuid())
  policyId     String
  order        Int
  delaySeconds Int
  targetType   EscalationTarget
  scheduleId   String?
  userId       String?
  notifyAll    Boolean          @default(false)

  policy   EscalationPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)
  schedule OnCallSchedule?  @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  user     User?            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([policyId, order])
}

enum EscalationTarget {
  SCHEDULE
  USER
  TEAM
}

// Alert auditing
model AlertDelivery {
  id                    String   @id @default(uuid())
  incidentId            String
  notificationChannelId String
  targetUserId          String?
  eventType             String
  status                String?
  providerMessage       String?
  createdAt             DateTime @default(now())

  incident            Incident            @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  notificationChannel NotificationChannel @relation(fields: [notificationChannelId], references: [id], onDelete: Cascade)
  targetUser          User?               @relation(fields: [targetUserId], references: [id])

  @@index([incidentId])
  @@index([targetUserId])
}
