generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String                @id @default(uuid())
  email                String                @unique
  firstName            String
  lastName             String
  role                 String                @default("owner")
  password             String
  sessions             Session[]
  monitors             Monitor[]
  notificationChannels NotificationChannel[]
}

model Monitor {
  id          String      @id @default(uuid())
  userId      String
  name        String
  type        MonitorType
  target      String
  regions     REGION[]
  intervalSec Int         @default(60)
  nextCheckAt DateTime    @default(now())
  paused      Boolean     @default(false)
  config      Json
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user                        User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  checkResults                MonitorCheckResult[]
  statusPage                  StatusPage?
  incidents                   Incident[]
  monitorNotificationChannels MonitorNotificationChannel[]

  @@index([userId])
  @@index([nextCheckAt, paused])
}

