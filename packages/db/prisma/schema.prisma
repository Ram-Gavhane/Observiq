// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String                @id @default(uuid())
  email                String                @unique
  password             String
  websites             Website[]
  notificationChannels NotificationChannel[]
}

model Website {
  id          String   @id @default(uuid())
  url         String
  userId      String
  regions     REGION[]
  timeAdded   DateTime @default(now())
  nextCheckAt DateTime @default(now())

  ticks                       WebsiteTick[]
  user                        User                         @relation(fields: [userId], references: [id])
  statusPage                  StatusPage?
  alerts                      Alerts[]
  websiteNotificationChannels WebsiteNotificationChannel[]
}

model StatusPage {
  id          String   @id @default(uuid())
  title       String
  description String?
  websiteId   String   @unique
  website     Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

enum REGION {
  US
  EU
  INDIA
}

model WebsiteTick {
  id             String        @id @default(uuid())
  responseTimeMs Int
  status         WebsiteStatus
  region         REGION
  website        Website       @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  websiteId      String
  createdAt      DateTime      @default(now())
}

enum WebsiteStatus {
  UP
  DOWN
  UNKNOWN
}

model NotificationChannel {
  id        String   @id @default(uuid())
  userId    String
  type      String // "email" | "sms" | "slack"
  config    Json // { "email": "john@doe.com" }
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user                        User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  alerts                      Alerts[]
  websiteNotificationChannels WebsiteNotificationChannel[]
}

model WebsiteNotificationChannel {
  websiteId String
  website   Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  notificationChannelId String
  notificationChannel   NotificationChannel @relation(fields: [notificationChannelId], references: [id], onDelete: Cascade)

  @@id([websiteId, notificationChannelId])
}

model Alerts {
  id                    String    @id @default(cuid())
  websiteId             String
  notificationChannelId String?
  status                String    @default("triggered") // "triggered" | "escalated" | "resolved"
  alertCount            Int       @default(0)
  escalated             Boolean   @default(false)
  triggeredAt           DateTime  @default(now())
  resolvedAt            DateTime?
  lastAlertedAt         DateTime?

  website             Website              @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  notificationChannel NotificationChannel? @relation(fields: [notificationChannelId], references: [id], onDelete: SetNull)
  incidentEvents      IncidentEvent[]

  @@unique([websiteId, notificationChannelId])
}

model IncidentEvent {
  id        String   @id @default(cuid())
  alertId   String
  type      String
  message   String
  createdAt DateTime @default(now())

  alert Alerts @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@index([alertId])
}
